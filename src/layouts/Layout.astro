---
import "@/styles/globals.css";

import { ToastContainer } from "react-toastify";

interface Props {
    className?: string;
}

const { className } = Astro.props;

const manifestHref = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/manifest.webmanifest`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <link
            rel="icon"
            type="image/x-icon"
            href="https://taibeled.github.io/JetLagHideAndSeek/favicon.ico"
        />
        <link
            rel="shortcut icon"
            type="image/x-icon"
            href="https://taibeled.github.io/JetLagHideAndSeek/favicon.ico"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="https://taibeled.github.io/JetLagHideAndSeek/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="https://taibeled.github.io/JetLagHideAndSeek/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="https://taibeled.github.io/JetLagHideAndSeek/favicon-16x16.png"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        {/*
          These three <script> tags are deliberately inline-verbatim.
          Astro's default is to run <script> through Vite (TS support,
          module bundling, hashed filenames) — but:
            - Partytown requires the literal `type="text/partytown"`
              MIME type so its patcher can hoist the script into a
              web worker. Bundling strips the type.
            - The Clarity loader is an IIFE that references `window`
              directly and injects its own <script> tag; Astro's
              module processing breaks the `(c, l, a, r, i, t, y)`
              pattern.
          `is:inline` tells Astro "yes, skip processing, on purpose"
          and silences the ts hint about implicit inlining.
        */}
        <script
            is:inline
            type="text/partytown"
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-RKJ9G6CNC2"
        ></script>
        <script is:inline type="text/partytown">
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                // eslint-disable-next-line prefer-rest-params
                dataLayer.push(arguments);
            }
            gtag("js", new Date());

            gtag("config", "G-RKJ9G6CNC2");
        </script>
        <script is:inline>
            if (!window.location.host.includes("localhost")) {
                (function (c, l, a, r, i, t, y) {
                    c[a] =
                        c[a] ||
                        function () {
                            // eslint-disable-next-line prefer-rest-params
                            (c[a].q = c[a].q || []).push(arguments);
                        };
                    t = l.createElement(r);
                    t.async = 1;
                    t.src = "https://www.clarity.ms/tag/" + i;
                    y = l.getElementsByTagName(r)[0];
                    y.parentNode.insertBefore(t, y);
                })(window, document, "clarity", "script", "sus45mfdvm");
            }
        </script>
        <meta name="generator" content={Astro.generator} />
        <!-- HTML Meta Tags -->
        <title>Map Generator for Jet Lag The Game: Hide and Seek</title>
        <meta
            name="description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />

        <!-- Facebook Meta Tags -->
        <meta
            property="og:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta property="og:type" content="website" />
        <meta
            property="og:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            property="og:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            property="og:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        <!-- Twitter Meta Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content="taibeled.github.io" />
        <meta
            property="twitter:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta
            name="twitter:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            name="twitter:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            name="twitter:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        <link rel="manifest" href={manifestHref} />
    </head>
    <body class:list={[className, "dark", "flex", "flex-col", "min-h-svh"]} style="touch-action: manipulation;">
        <slot />
        <ToastContainer client:only="react" />
    </body>
</html>
